<div class="messages-container">
  <h2>Messages (Dynamic)</h2>
  
  <div class="controls">
    <button id="refresh-btn" onclick="loadMessages()">Refresh Messages</button>
    <button id="add-message-btn" onclick="showAddMessageForm()">Add Message</button>
  </div>

  <div id="error-container" class="error" style="display: none;">
    <p id="error-message"></p>
  </div>

  <div id="loading" class="loading" style="display: none;">
    <p>Loading messages...</p>
  </div>

  <ul id="messages-list" class="messages-list">
    <!-- Messages will be dynamically loaded here -->
  </ul>

  <!-- Add Message Form (hidden by default) -->
  <div id="add-message-form" class="add-message-form" style="display: none;">
    <h3>Add New Message</h3>
    <form id="message-form" onsubmit="addMessage(event)">
      <div class="form-group">
        <label for="message-text">Message:</label>
        <textarea id="message-text" required></textarea>
      </div>
      <div class="form-group">
        <label for="user-id">User ID:</label>
        <input type="text" id="user-id" required>
      </div>
      <div class="form-actions">
        <button type="submit">Send Message</button>
        <button type="button" onclick="hideAddMessageForm()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<style>
.messages-container {
  max-width: 800px;
  margin: 0 auto;
  padding: 20px;
}

.controls {
  margin-bottom: 20px;
}

.controls button {
  background: #007bff;
  color: white;
  border: none;
  padding: 10px 15px;
  border-radius: 4px;
  margin-right: 10px;
  cursor: pointer;
}

.controls button:hover {
  background: #0056b3;
}

.messages-list {
  list-style: none;
  padding: 0;
}

.message-item {
  background: #f5f5f5;
  border: 1px solid #ddd;
  border-radius: 8px;
  margin-bottom: 10px;
  padding: 15px;
}

.message-content {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.message-text {
  font-size: 16px;
  color: #333;
  margin: 0;
}

.message-meta {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: #666;
}

.message-user {
  font-weight: bold;
}

.error {
  background: #ffebee;
  border: 1px solid #f44336;
  border-radius: 4px;
  padding: 10px;
  margin-bottom: 20px;
  color: #c62828;
}

.loading {
  text-align: center;
  padding: 20px;
  color: #666;
}

.add-message-form {
  background: #f8f9fa;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 20px;
  margin-top: 20px;
}

.form-group {
  margin-bottom: 15px;
}

.form-group label {
  display: block;
  margin-bottom: 5px;
  font-weight: bold;
}

.form-group input,
.form-group textarea {
  width: 100%;
  padding: 8px;
  border: 1px solid #ddd;
  border-radius: 4px;
  font-size: 14px;
}

.form-group textarea {
  height: 80px;
  resize: vertical;
}

.form-actions {
  display: flex;
  gap: 10px;
}

.form-actions button {
  padding: 8px 15px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
}

.form-actions button[type="submit"] {
  background: #28a745;
  color: white;
}

.form-actions button[type="button"] {
  background: #6c757d;
  color: white;
}
</style>

<script>
// Load messages when page loads
document.addEventListener('DOMContentLoaded', loadMessages);

async function loadMessages() {
  const loading = document.getElementById('loading');
  const errorContainer = document.getElementById('error-container');
  const errorMessage = document.getElementById('error-message');
  const messagesList = document.getElementById('messages-list');
  
  // Show loading
  loading.style.display = 'block';
  errorContainer.style.display = 'none';
  
  try {
    const response = await fetch('/api/messages');
    const data = await response.json();
    
    loading.style.display = 'none';
    
    if (data.status === 'success' && data.data.messages) {
      renderMessages(data.data.messages);
    } else {
      showError('Failed to load messages');
      renderMessages([]);
    }
  } catch (error) {
    loading.style.display = 'none';
    showError('Error loading messages: ' + error.message);
    renderMessages([]);
  }
}

function renderMessages(messages) {
  const messagesList = document.getElementById('messages-list');
  
  if (messages.length === 0) {
    messagesList.innerHTML = '<li class="message-item"><p>No messages available</p></li>';
    return;
  }
  
  messagesList.innerHTML = messages.map(message => `
    <li class="message-item">
      <div class="message-content">
        <p class="message-text">${message.text}</p>
        <div class="message-meta">
          <span class="message-user">User: ${message.userId}</span>
          <span class="message-time">${new Date(message.timestamp).toLocaleString()}</span>
        </div>
      </div>
    </li>
  `).join('');
}

function showError(message) {
  const errorContainer = document.getElementById('error-container');
  const errorMessage = document.getElementById('error-message');
  
  errorMessage.textContent = message;
  errorContainer.style.display = 'block';
}

function showAddMessageForm() {
  document.getElementById('add-message-form').style.display = 'block';
}

function hideAddMessageForm() {
  document.getElementById('add-message-form').style.display = 'none';
  document.getElementById('message-form').reset();
}

async function addMessage(event) {
  event.preventDefault();
  
  const text = document.getElementById('message-text').value;
  const userId = document.getElementById('user-id').value;
  
  try {
    const response = await fetch('/api/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({ text, userId })
    });
    
    const data = await response.json();
    
    if (data.status === 'success') {
      hideAddMessageForm();
      loadMessages(); // Refresh the messages list
    } else {
      showError('Failed to add message: ' + data.message);
    }
  } catch (error) {
    showError('Error adding message: ' + error.message);
  }
}
</script>
